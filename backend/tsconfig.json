{
  "compilerOptions": {
    "target": "ES2020",              // ✅ IMPORTANT
    "module": "CommonJS",
    "lib": ["ES2020"],
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,         // ✅ fixes other default import errors too
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "downlevelIteration": true       // ✅ fixes MapIterator error
  }
}